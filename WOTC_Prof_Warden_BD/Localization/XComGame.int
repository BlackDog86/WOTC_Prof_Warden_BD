[WOTC_Prof_Warden_BD X2SoldierClassTemplate]
DisplayName="Warden"
ClassSummary="Wardens are a militarised wing of the Templars which act as front-line and supporting class. They possess two stances, <font color='#CA7200'>Ranged Stance</font> and <font color='#0058CA'>Melee Stance</font>. These stances switch at the end of a turn, if an attack with a matching stance/weapon combination is made. Such attacks also grant the warden a <font color='#8f3fbf'>flow</font> action point which can be used to activate powerful supporting abilities."
AbilityTreeTitles[0]="Inquisitor"
AbilityTreeTitles[1]="Spiritblade"
AbilityTreeTitles[2]="Adept"
AbilityTreeTitles[3]="Disciple"

RankIcons[0]= "UILibrary_Common.rank_rookie"
RankIcons[1]= "UILibrary_Common.psirank_initiate"
RankIcons[2]= "UILibrary_Common.psirank_adept"
