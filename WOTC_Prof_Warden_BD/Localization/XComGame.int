[Warden_BD_Fissure X2AbilityTemplate]
LocFriendlyName="Sundering Sigil"
LocLongDescription="Place a large psionic ward on the ground. Organic enemies will receive <font color='#CA7200'><Ability:FISSURE_INITIAL_AMOUNT/></font> stack of rupture and a further <font color='#CA7200'><Ability:FISSURE_AMOUNT/></font> stacks if they remain inside the ward at the end of the turn. <font color='#CA7200'><Ability:FISSURE_COOLDOWN/></font>-turn cooldown."
LocHelpText="Place a large psionic ward on the ground. Organic enemies will receive <font color='#CA7200'><Ability:FISSURE_INITIAL_AMOUNT/></font> stack of rupture and a further <font color='#CA7200'><Ability:FISSURE_AMOUNT/></font> stacks if they remain inside the ward at the end of the turn. <font color='#CA7200'><Ability:FISSURE_COOLDOWN/></font>-turn cooldown."
