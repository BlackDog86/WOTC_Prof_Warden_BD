[WOTC_Prof_Warden_BD X2SoldierClassTemplate]
DisplayName="Warden"
ClassSummary="Wardens are a militarised wing of the Templars which act as front-line and supporting class. They possess two stances (ranged and melee), which alternate based on battlefield conditions. Carrying out an attack with a matching stance/weapon combination grants the warden attack bonuses and a <font color='#b6b3e3'>flow</font> action point at the end of the turn which they can use to activate powerful supporting abilities."
AbilityTreeTitles[0]="Inquisitor"
AbilityTreeTitles[1]="Spiritblade"
AbilityTreeTitles[2]="Adept"
AbilityTreeTitles[3]="Disciple"

RankIcons[0]= "UILibrary_Common.rank_rookie"
RankIcons[1]= "UILibrary_Common.psirank_initiate"
RankIcons[2]= "UILibrary_Common.psirank_adept"
