[WOTC_Warden_BD X2EncyclopediaTemplate]
ListTitle = "Warden Class"
DescriptionTitle = "Warden Class"
DescriptionEntry="Wardens represent a special military wing of the Templar order. Recruits who prove themselves worthy to the templar cause but are slightly lacking in psionic potential may be drafted into the Wardens instead. Wardens are highly capable soldiers who excel in using the Ebb and Flow of psionic energy on the battlefield to support their skills. Wardens are granted access to ranged and <font color='#0058CA'>Melee stance</font>s which boost capabilities with each weapon when in the correct stance. Carrying out successful attacks from the correct stance will also grant the Warden access to additional abilities that can change the course of a battle."

[WOTC_Prof_Warden_BD_Unlock1 X2SoldierAbilityUnlockTemplate]
DisplayName = "Warden: Concentration I"
Summary = "All stance proficiencies will now start at level 2, regardless of soldier rank. Gain an additional charge of <font color='#b6b3e3'>Flow Mastery</font>."

[WOTC_Prof_Warden_BD_Unlock2 X2SoldierAbilityUnlockTemplate]
DisplayName = "Warden: Concentration II"
Summary = "All stance proficiencies will now start at level 3, regardless of soldier rank. Gain an additional charge of <font color='#b6b3e3'>Flow Mastery</font>."

[X2Ability_Warden]
BrandedFriendlyName = "Branded"

