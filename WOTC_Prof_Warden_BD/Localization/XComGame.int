[Warden_BD_LastRites X2AbilityTemplate]
LocFriendlyName="Last Rites"
LocHelpText="Gain <font color='#CA7200'><Ability:LAST_RITES_SOULBLADE_CHARGES/></font> soul-blade charges. Thrust your blade into an enemy and snap it off, leaving behind a fragment of your sword's energy and teleport back to your turn start position. The fragment detonates in <font color='#CA7200'><Ability:LAST_RITES_DURATION/></font> turns, or on the next instance of psionic damage, dealing damage equal to that of all charges deposited. <font color='#CA7200'><Ability:LAST_RITES_COOLDOWN/></font>-turn cooldown. Requires <font color='#0058CA'>Melee stance</font>."
LocLongDescription="Gain <font color='#CA7200'><Ability:LAST_RITES_SOULBLADE_CHARGES/></font> soul-blade charges. Thrust your blade into an enemy and snap it off, leaving behind a fragment of your sword's energy. The fragment detonates in <font color='#CA7200'><Ability:LAST_RITES_DURATION/></font> turns, or on the next instance of psionic damage, dealing damage equal to that of all charges deposited. <font color='#CA7200'><Ability:LAST_RITES_COOLDOWN/></font>-turn cooldown. Requires <font color='#0058CA'>Melee stance</font>."
LocFlyOverText="Last Rites"

[Warden_BD_LastRitesDetonation X2AbilityTemplate]
LocFriendlyName="Last Rites"
LocHelpText="The psionic charge detonates."
LocLongDescription="The psionic charge planted by Last Rites detonates, dealing massive damage and shredding armour."
LocFlyOverText="Last Rites — Detonation"

[Warden_BD_LastRitesCharge X2AbilityTemplate]
LocFriendlyName="Last Rites"
LocHelpText="This unit has been marked by a Warden's Last Rites. The unit will receive damage from a devastating detonation in <font color='#CA7200'><Ability:LAST_RITES_DURATION/></font> turns, or on the next instance of psionic damage."
LocLongDescription="This unit has been marked by a Warden's Last Rites. The unit will receive damage from a devastating detonation in <font color='#CA7200'><Ability:LAST_RITES_DURATION/></font> turns, or on the next instance of psionic damage."
LocFlyOverText="Last Rites"

[Warden_BD_Charge X2AbilityTemplate]
LocFriendlyName="Warden's Call"
LocLongDescription="Grants 3 <font color='#b6b3e3'>flow</font> action points which may be used on any abilities of the warden's choosing (Excluding Astral Barrage and Last Rites). <font color='#CA7200'><Ability:CHARGE_COOLDOWN/></font>-turn cooldown"
LocHelpText="Grants 3 <font color='#b6b3e3'>flow</font> action points which may be used on any abilities of the warden's choosing (Excluding Astral Barrage and Last Rites). <font color='#CA7200'><Ability:CHARGE_COOLDOWN/></font>-turn cooldown"
LocFlyOverText="Warden's Call"

[Warden_BD_FlowFocusPassive X2AbilityTemplate]
LocFriendlyName="Flow Focus"
LocLongDescription="Resets cooldowns on all abilities which can be activated with <font color='#b6b3e3'>flow</font> action points. Free Action. <font color='#CA7200'><Ability:FLOWFOCUS_COOLDOWN/></font>-turn cooldown"
LocHelpText="Resets cooldowns on all abilities which can be activated with <font color='#b6b3e3'>flow</font> action points. Free Action. <font color='#CA7200'><Ability:FLOWFOCUS_COOLDOWN/></font>-turn cooldown"
LocFlyOverText="Flow Focus"

[Warden_BD_Retribution X2AbilityTemplate]
LocFriendlyName="Sigil of Retribution"
LocLongDescription="Place a large psionic ward on the ground. All friendly, organic units standing in the area of effect will have their overwatch penalties removed. Units remaining inside the ward at the end of the turn will be granted a free overwatch shot. <font color='#CA7200'><Ability:RETRIBUTION_COOLDOWN/></font>-turn cooldown."
LocHelpText="Place a large psionic ward on the ground. All friendly, organic units standing in the area of effect will have their overwatch penalties removed. Units remaining inside the ward at the end of the turn will be granted a free overwatch shot. <font color='#CA7200'><Ability:RETRIBUTION_COOLDOWN/></font>-turn cooldown."
LocFlyOverText="Sigil of Retribution"

[Warden_BD_Brand X2AbilityTemplate]
LocFriendlyName="Brand"
LocLongDescription = "Brand an enemy with a psionic hex, granting +<font color='#3ABD23'><Ability:BRAND_OFFENSE_STAT_BONUS/></font>% to hit and critical hit chance and +<font color='#3ABD23'><Ability:BRAND_DAMAGE_BONUS/></font> damage against the target on future attacks."
LocHelpText = "Brand an enemy, granting +<font color='#3ABD23'><Ability:BRAND_OFFENSE_STAT_BONUS/></font>% to Hit & Crit and +<font color='#3ABD23'><Ability:BRAND_DAMAGE_BONUS/></font> damage on future attacks."
LocFlyOverText="Brand"

[Warden_BD_Pillar X2AbilityTemplate]
LocFriendlyName="Pillar"
LocLongDescription="Create a large obelisk at the target location, granting high cover lasting for <font color='#CA7200'><Ability:PILLLAR_NUMBER_OF_TURNS/></font> turns. <font color='#CA7200'><Ability:PILLAR_COOLDOWN/></font>-turn cooldown."
LocHelpText="Create a pillar at the target location. Grants high cover lasting for <font color='#CA7200'><Ability:PILLLAR_NUMBER_OF_TURNS/></font> turns. <font color='#CA7200'><Ability:PILLAR_COOLDOWN/></font>-turn cooldown."
LocFlyOverText="Pillar"

[Warden_BD_Inspire X2AbilityTemplate]
LocFriendlyName="Warden's Inspiration"
LocLongDescription="Grant a standard action point to an ally. <font color='#CA7200'><Ability:INSPIRE_COOLDOWN/></font>-turn cooldown."
LocHelpText="Grant a standard action point to an ally. <font color='#CA7200'><Ability:INSPIRE_COOLDOWN/></font>-turn cooldown."
LocFlyOverText="Warden's Inspiration"

[Warden_BD_Fuse X2AbilityTemplate]
LocFriendlyName="Fuse"
LocLongDescription="Remotely detonate an enemy's equipped explosive. <font color='#CA7200'><Ability:FUSE_COOLDOWN/></font>-turn cooldown."
LocHelpText="Remotely detonate an enemy's equipped explosive. <font color='#CA7200'><Ability:FUSE_COOLDOWN/></font>-turn cooldown."
LocFlyOverText="Fuse"

[WOTC_Prof_Warden_BD_AcademyAbility1 X2AbilityTemplate]
LocFriendlyName="Warden: Warden's Concentration I"
LocLongDescription="Warden Proficiency abilities (+<font color='#CA7200'><Ability:MELEESTANCE_I_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MOBILITY_BONUS/></font> mobility, <font color='#CA7200'><Ability:WARDENSSWORD_AIM_I_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_II_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_III_BONUS/></font>sword aim, and <font color='#CA7200'><Ability:MELEESTANCE_I_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MELEE_DR/></font> melee damage reduction while in <font color='#0058CA'>Melee stance</font>, plus <font color='#CA7200'><Ability:RANGEDSTANCE_I_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CDEF_BONUS/></font>% reduction in enemy defense from cover and <font color='#CA7200'><Ability:RANGEDSTANCE_I_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CRIT_BONUS/></font>% critical hit chance in <font color='#CA7200'>Ranged stance</font> will start at the second proficiency level (Normally granted at Sergeant), regardless of soldier rank."
LocHelpText="Warden: Warden's Concentration I"
LocPromotionPopupText="Warden Proficiency abilities (+<font color='#CA7200'><Ability:MELEESTANCE_I_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MOBILITY_BONUS/></font> mobility, <font color='#CA7200'><Ability:WARDENSSWORD_AIM_I_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_II_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_III_BONUS/></font>sword aim, and <font color='#CA7200'><Ability:MELEESTANCE_I_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MELEE_DR/></font> melee damage reduction while in <font color='#0058CA'>Melee stance</font>, plus <font color='#CA7200'><Ability:RANGEDSTANCE_I_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CDEF_BONUS/></font>% reduction in enemy defense from cover and <font color='#CA7200'><Ability:RANGEDSTANCE_I_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CRIT_BONUS/></font>% critical hit chance in <font color='#CA7200'>Ranged stance</font> will start at the second proficiency level (Normally granted at Sergeant), regardless of soldier rank."
LocFlyOverText="Prof GTS Unlocks"

[WOTC_Prof_Warden_BD_AcademyAbility2 X2AbilityTemplate]
LocFriendlyName="Warden: Warden's Concentration II"
LocLongDescription="Warden Proficiency abilities (+<font color='#CA7200'><Ability:MELEESTANCE_I_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MOBILITY_BONUS/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MOBILITY_BONUS/></font> mobility, <font color='#CA7200'><Ability:WARDENSSWORD_AIM_I_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_II_BONUS/></font>/<font color='#CA7200'><Ability:WARDENSSWORD_AIM_III_BONUS/></font>sword aim, and <font color='#CA7200'><Ability:MELEESTANCE_I_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_II_MELEE_DR/></font>/<font color='#CA7200'><Ability:MELEESTANCE_III_MELEE_DR/></font> melee damage reduction while in <font color='#0058CA'>Melee stance</font>, plus <font color='#CA7200'><Ability:RANGEDSTANCE_I_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CDEF_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CDEF_BONUS/></font>% reduction in enemy defense from cover and <font color='#CA7200'><Ability:RANGEDSTANCE_I_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_II_CRIT_BONUS/></font>/<font color='#CA7200'><Ability:RANGEDSTANCE_III_CRIT_BONUS/></font>% critical hit chance in <font color='#CA7200'>Ranged stance</font> will start at the third proficiency level (Normally granted at Major), regardless of soldier rank."
